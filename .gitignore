# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Local on-device AI model artifacts are hundreds of MB. Keep them local and
# ship through release asset delivery or a private build artifact pipeline.
/android/app/src/main/assets/models/*.litertlm
/android/app/src/main/assets/models/*.task
/local_models/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase client configs — drop your own copy in before building.
# These are not secrets by Firebase's definition, but we keep them out
# of source control by policy. See `*.example` companion files for the
# expected shape.
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist

# Local signing key (release builds). Keep out of git.
/android/key.properties
/android/app/upload-keystore.jks
/android/app/release.keystore
