# Firebase client configs \u2014 drop your own copy in before building.
# These are not secrets by Firebase's definition, but we keep them out of
# source control by policy. Use the `.example` files as templates.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Large AI model weights \u2014 downloaded by scripts/download_local_ai_model.sh
# See the README for setup. Do not commit, GitHub's 100 MB/file limit applies.
android/app/src/main/assets/models/*.litertlm
android/app/src/main/assets/models/*.tflite
android/app/src/main/assets/models/*.bin
!android/app/src/main/assets/models/.gitkeep

